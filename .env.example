# Site
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Sentry (optional; omit to disable error reporting)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional source maps in CI
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Cache revalidation (optional scheduled / manual post cache bust)
# CRON_SECRET=Vercel Cron Bearer token
# REVALIDATE_SECRET=shared secret for GET /api/revalidate-posts?secret=
CRON_SECRET=
REVALIDATE_SECRET=

# Admin (required for /admin)
ADMIN_PASSWORD=your-secure-password
# Optional: separate secret for signed session cookies (recommended in production)
ADMIN_SESSION_SECRET=

# Supabase (required for persisted posts; omit to use sample posts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (for newsletter and contact form)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=you@yourdomain.com

# AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
